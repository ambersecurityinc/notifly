---
const features = [
	{
		icon: '🌐',
		title: 'Web API Only',
		desc: 'No Node built-ins. CF Workers, Bun, Deno, Node 18+.',
	},
	{
		icon: '🔗',
		title: 'URL Schemes',
		desc: 'Portable config. One string per service.',
	},
	{
		icon: '🧩',
		title: 'Plugin System',
		desc: 'Built-in services + registerService() to extend.',
	},
	{
		icon: '📋',
		title: 'Headless Builder',
		desc: 'Schema-driven URL builder. Bring your own UI.',
	},
];
---

<div
	style="display:grid;grid-template-columns:repeat(4,1fr);gap:36px;"
	class="feature-grid"
>
	{
		features.map((f) => (
			<div>
				<div style="font-size:26px;margin-bottom:10px;">{f.icon}</div>
				<h3
					style="font-family:var(--font-heading);font-size:15px;font-weight:700;color:var(--color-text);margin-bottom:6px;"
				>
					{f.title}
				</h3>
				<p style="font-size:13px;color:#555;line-height:1.6;font-family:var(--font-heading);">
					{f.desc}
				</p>
			</div>
		))
	}
</div>

<style>
	@media (max-width: 768px) {
		.feature-grid {
			grid-template-columns: repeat(2, 1fr) !important;
			gap: 20px !important;
		}
	}
</style>
