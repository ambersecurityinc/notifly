---
const services = [
	{ name: 'Discord', scheme: 'discord://', color: '#5865F2' },
	{ name: 'Slack', scheme: 'slack://', color: '#E01E5A' },
	{ name: 'Telegram', scheme: 'tgram://', color: '#26A5E4' },
	{ name: 'Teams', scheme: 'msteams://', color: '#6264A7' },
	{ name: 'ntfy', scheme: 'ntfy://', color: '#57A85C' },
	{ name: 'Gotify', scheme: 'gotify://', color: '#3F8EBF' },
	{ name: 'Pushover', scheme: 'pover://', color: '#249DF1' },
];
---

<div style="position:relative;height:320px;overflow:hidden;" id="hero-anim">
	<div
		style="position:absolute;left:0;top:50%;transform:translateY(-50%);width:32px;height:32px;border-radius:50%;background:var(--color-accent-dim);border:1px solid var(--color-accent-border);display:flex;align-items:center;justify-content:center;font-size:14px;z-index:2;"
	>
		⚡
	</div>
	{
		services.map((s, i) => (
			<div
				class="flying-notif"
				style={`position:absolute;right:calc(100% + 60px);top:${i * 44 + 8}px;display:flex;align-items:center;gap:6px;background:rgba(20,20,20,0.85);backdrop-filter:blur(12px);border:1px solid ${s.color}33;border-radius:7px;padding:5px 10px;white-space:nowrap;font-size:11px;font-family:var(--font-mono);color:${s.color};box-shadow:0 0 16px ${s.color}12;transition:right 1.2s cubic-bezier(0.16,1,0.3,1);`}
				data-delay={i * 200 + 200}
			>
				<span
					style={`width:6px;height:6px;border-radius:50%;background:${s.color};display:inline-block;flex-shrink:0;`}
				/>
				{s.scheme}<span style="color:#666;">…</span>
			</div>
		))
	}
</div>

<script>
	const notifs = document.querySelectorAll<HTMLElement>('.flying-notif');
	notifs.forEach((el) => {
		const delay = Number(el.getAttribute('data-delay') ?? 0);
		setTimeout(() => {
			el.style.right = '8px';
		}, delay);
	});
</script>
