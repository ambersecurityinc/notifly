<footer
	style="border-top:1px solid #111;padding:24px 40px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;max-width:1200px;margin:0 auto;"
	class="site-footer"
>
	<div style="display:flex;align-items:center;gap:6px;">
		<div style="width:5px;height:5px;border-radius:50%;background:var(--color-accent);"></div>
		<span style="font-family:var(--font-heading);font-size:11px;color:#444;"
			>@ambersecurityinc/notifly</span
		>
	</div>
	<div style="display:flex;gap:20px;align-items:center;flex-wrap:wrap;">
		<a
			href="https://github.com/ambersecurityinc/notifly"
			style="font-family:var(--font-mono);font-size:10px;color:#333;"
			target="_blank"
			rel="noopener">GitHub</a
		>
		<a
			href="https://www.npmjs.com/package/@ambersecurityinc/notifly"
			style="font-family:var(--font-mono);font-size:10px;color:#333;"
			target="_blank"
			rel="noopener">npm</a
		>
		<span style="font-family:var(--font-mono);font-size:10px;color:#333;"
			>MIT License · Amber Security</span
		>
	</div>
</footer>

<style>
	@media (max-width: 768px) {
		.site-footer {
			padding: 20px !important;
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
