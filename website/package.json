{
	"name": "notifly-website",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"deploy": "npm run build && wrangler pages deploy dist",
		"deploy:prod": "npm run build && wrangler pages deploy dist --project-name notifly-website --branch main"
	},
	"devDependencies": {
		"@astrojs/cloudflare": "14.1.2",
		"@astrojs/sitemap": "3.7.3",
		"@biomejs/biome": "2.5.3",
		"@tailwindcss/vite": "4.3.3",
		"astro": "7.0.7",
		"tailwindcss": "4.3.3",
		"wrangler": "4.110.0"
	}
}
