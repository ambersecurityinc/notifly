{
  "name": "@ambersecurityinc/notifly",
  "version": "0.4.0",
  "description": "Send notifications to multiple services from a single API using Apprise-compatible URLs",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./builder": {
      "types": "./dist/builder/index.d.ts",
      "import": "./dist/builder/index.js",
      "require": "./dist/builder/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/builder/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts src/builder/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "release": "changeset publish"
  },
  "keywords": [
    "notifications",
    "discord",
    "slack",
    "telegram",
    "ntfy",
    "gotify",
    "apprise"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ambersecurityinc/notifly.git"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@vitest/coverage-v8": "4.1.4",
    "tsup": "8.5.1",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
